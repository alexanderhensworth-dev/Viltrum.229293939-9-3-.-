local fTr,iTr,gTr,boTr,sTr,cgTr,hTr,hTdTr,hlTr,hLndTr
local aS="none"

local function frz(t) if t then t.Looped=false end end
local function hld(t,o,f)
	if not t then return end
	local tt=o
	if t.Length>0 then tt=o%t.Length end
	if not t.IsPlaying then t:Play(f or 0,1,0) end
	t.TimePosition=tt
	t:AdjustSpeed(0)
end

local function ldA()
	local ids=AIDS[rig]
	local function ld(id,p)
		if not id then return nil end
		local a=Instance.new("Animation")
		a.AnimationId=id
		local t=anim:LoadAnimation(a)
		t.Priority=p or Enum.AnimationPriority.Action
		return t
	end
	fTr=ld(ids.FLY) iTr=ld(ids.IDLE) gTr=ld(ids.FALL)
	boTr=ld(ids.B1) sTr=ld(ids.B2) hTr=ld(ids.HOV) hlTr=ld(ids.HL)
	if rig=="R15" then
		cgTr=ld(ids.CHG)
		hLndTr=ld(ids.HOV_LND)
		fTr.Looped=true
		if P_OFF.IDLE then frz(iTr) end
		if P_OFF.B1 then frz(boTr) end
		if P_OFF.HOV_LND then frz(hLndTr) end
	else
		hTdTr=ld(ids.HOVTD)
		fTr.Looped=true
		for _,t in ipairs({iTr,boTr,sTr,hTr,hTdTr,hlTr}) do frz(t) end
	end
end

local function sAS(ns,fd)
	if rig~="R6" then return end
	if aS==ns then return end
	fd=fd or 0.3
	local old=aS aS=ns
	local activeIdleTr=P_OFF.IDLE and iTr or hTdTr
	local activeIdleOff=P_OFF.IDLE or OFF.H2
	local stops={idle=activeIdleTr,fly=fTr,boost1=boTr,boost2=sTr,hover=hTdTr,hoverTouchdown=hTdTr,glide=gTr,hardland=hlTr}
	local s=stops[old]
	if s and s.IsPlaying then s:Stop(fd) end
	if ns=="idle" then hld(activeIdleTr,activeIdleOff,fd)
	elseif ns=="fly" then if fTr and not fTr.IsPlaying then fTr:Play(fd) fTr:AdjustSpeed(1) end
	elseif ns=="boost1" then hld(boTr,OFF.B1,fd)
	elseif ns=="boost2" then hld(sTr,OFF.B2,fd)
	elseif ns=="hover" then hld(hTdTr,OFF.H2,fd)
	elseif ns=="hoverTouchdown" then hld(hTdTr,OFF.H2,fd)
	elseif ns=="hardland" then hld(hlTr,OFF.LN,fd)
	end
end

