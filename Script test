local function ldIt()
	if ldI then return end ldI=true
	if not curPg then
		local sp=CatalogSearchParams.new() sp.AssetTypes=curAT sp.Limit=30 sp.SortType=Enum.CatalogSortType.Relevance
		if curSr~="" then sp.SearchKeyword=curSr end
		local ok,res=pcall(function() return AES:SearchCatalog(sp) end)
		if ok and res then curPg=res for _,item in ipairs(curPg:GetCurrentPage()) do mkIt(item) end end
	else
		if not curPg.IsFinished then
			local ok=pcall(function() curPg:AdvanceToNextPageAsync() end)
			if ok then for _,item in ipairs(curPg:GetCurrentPage()) do mkIt(item) end end
		end
	end
	ldI=false
end

