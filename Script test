local function wAc(aid)
	local c=plr.Character if not c then return end
	local h=c:FindFirstChildOfClass("Humanoid") if not h then return end
	for _,ch in ipairs(c:GetChildren()) do if ch:GetAttribute("AssetID")==aid then return end end
	local ok,objs=pcall(function() return game:GetObjects("rbxassetid://"..tostring(aid)) end)
	if not ok or not objs or #objs==0 then return end
	for _,w in ipairs(objs) do
		local ts={}
		if w:IsA("Model") and w.Name=="Model" then ts=w:GetChildren() else table.insert(ts,w) end
		for _,obj in ipairs(ts) do
			local em=c:FindFirstChild(obj.Name)
			if em and em:GetAttribute("AssetID")==aid then em:Destroy() end
			obj:SetAttribute("AssetID",aid)
			if obj:IsA("Accessory") then
				local cl=obj:Clone() cl.Parent=c h:AddAccessory(cl)
				local hdl=cl:FindFirstChild("Handle")
				if hdl and hdl:IsA("BasePart") then
					hdl.CanCollide=false
					local at=hdl:FindFirstChildOfClass("Attachment")
					local tp=c:FindFirstChild("Head")
					if at then for _,l in ipairs(c:GetChildren()) do if l:IsA("BasePart") and l:FindFirstChild(at.Name) then tp=l break end end end
					if tp then
						local ta=tp:FindFirstChild(at and at.Name or "")
						local wd=hdl:FindFirstChild("AccessoryWeld") or Instance.new("Weld")
						wd.Name="AccessoryWeld" wd.Part0=hdl wd.Part1=tp
						if at and ta then wd.C0=at.CFrame wd.C1=ta.CFrame else wd.C0=CFrame.new(0,0,0) end
						wd.Parent=hdl
					end
				end
			elseif obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("ShirtGraphic") then
				local it=c:FindFirstChildOfClass(obj.ClassName) if it then it:Destroy() end
				obj:Clone().Parent=c
			end
		end
		w:Destroy()
	end
	_G.PWI[aid]=true uW()
end

